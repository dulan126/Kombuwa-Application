# ── Server ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=miedvance
DB_USER=miedvance_user
DB_PASSWORD=your_strong_password_here

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here_change_in_production
JWT_EXPIRES_IN=30d
JWT_REFRESH_SECRET=your_refresh_token_secret_here_also_change
JWT_REFRESH_EXPIRES_IN=30d

# ── SMS (Dialog Axiata / Mobitel) ────────────────────────────────────
SMS_PROVIDER=dialog
SMS_API_URL=https://richcommunication.dialog.lk/api/sms/
SMS_API_KEY=your_dialog_sms_api_key
SMS_SENDER_ID=MIEDVANCE

# ── File Storage ─────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Frontend ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:8080,https://miedvance.com

# ── OTP ──────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
